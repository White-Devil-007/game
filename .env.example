# Google Gemini API Configuration
# Get your free API key at: https://makersuite.google.com/app/apikey

# Primary API Key (required for full functionality)
GEMINI_API_KEY=your_api_key_here

# Optional: Backup API Keys for key rotation
# The system will rotate through these if one hits rate limits or quota.
GEMINI_API_KEY_1=first_backup_key_here
GEMINI_API_KEY_2=second_backup_key_here
GEMINI_API_KEY_3=third_backup_key_here

# Note: If no API keys are provided, Gemini-only mode cannot operate.
# The backend will return 503 errors until a valid API key is configured.
